{
  "name": "calendar",
  "version": "1.0.0",
  "schema_version": 1,
  "description": "View Google Calendar events",
  "author": "tamux",
  "license": "MIT",
  "tamux_version": ">=2.0.0",
  "auth": {
    "type": "oauth2",
    "authorization_url": "https://accounts.google.com/o/oauth2/v2/auth",
    "token_url": "https://oauth2.googleapis.com/token",
    "scopes": ["https://www.googleapis.com/auth/calendar.readonly"],
    "pkce": true
  },
  "settings": {
    "default_calendar": {
      "type": "string",
      "label": "Calendar ID",
      "required": false,
      "default": "primary",
      "description": "Calendar ID to query (default: primary)"
    }
  },
  "api": {
    "base_url": "https://www.googleapis.com",
    "endpoints": {
      "list_events_today": {
        "method": "GET",
        "path": "/calendar/v3/calendars/{{default params.calendar_id \"primary\"}}/events?singleEvents=true&orderBy=startTime&timeMin={{params.time_min}}&timeMax={{params.time_max}}&maxResults={{default params.max_results \"20\"}}",
        "response_template": "## Today's Calendar\n\n{{#each items}}Event: {{summary}}\nStart: {{default start.dateTime start.date}}\nEnd: {{default end.dateTime end.date}}\nLocation: {{default location \"No location\"}}\n\n{{/each}}"
      }
    },
    "rate_limit": {
      "requests_per_minute": 60
    }
  },
  "commands": {
    "today": {
      "description": "Show today's calendar events",
      "action": "list_events_today"
    }
  },
  "skills": ["skills/calendar-today.yaml"]
}
